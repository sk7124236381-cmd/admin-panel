<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nexus - Master Admin Panel</title>
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <!-- External Libraries for Charts and PDF Export -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>

    <style>
        /* --- Modern Dashboard Theme Variables --- */
        :root {
            --primary-bg: #0b0f19; --secondary-bg: #141b2d; --card-bg: #1a2235; --sidebar-bg: #0b0f19;
            --text-primary: #f8fafc; --text-secondary: #94a3b8; --accent-color: #3b82f6;
            --accent-gradient: linear-gradient(135deg, #3b82f6, #8b5cf6);
            --primary-button-bg: #3b82f6; --primary-button-hover: #2563eb;
            --border-color: rgba(255, 255, 255, 0.08);
            --success-color: #10b981; --danger-color: #ef4444; --warning-color: #f59e0b; --info-color: #0ea5e9;
            --placeholder-bg: rgba(148, 163, 184, 0.1);
        }

        /* --- Global Resets & Scrollbars --- */
        body { background-color: var(--primary-bg); color: var(--text-primary); font-family: 'Inter', sans-serif; overflow-x: hidden; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: var(--primary-bg); }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #475569; }

        /* --- Animations --- */
        .section { display: none; opacity: 0; transform: translateY(10px); transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
        .section.active { display: block; opacity: 1; transform: translateY(0); animation: slideUpFade 0.4s ease forwards; }
        @keyframes slideUpFade { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }

        /* --- Layout: Header & Sidebar --- */
        .app-header {
            position: fixed; top: 0; left: 0; right: 0; height: 70px;
            background: rgba(20, 27, 45, 0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
            display: flex; align-items: center; justify-content: space-between; padding: 0 24px;
            border-bottom: 1px solid var(--border-color); z-index: 1030; transition: left 0.3s ease;
        }
        .header-title { font-size: 1.1rem; font-weight: 700; letter-spacing: -0.02em; margin: 0; color: #fff;}
        .menu-toggle-btn { background: none; border: none; color: var(--text-primary); font-size: 1.5rem; padding: 0; margin-right: 15px;}
        
        .offcanvas-start { background-color: var(--sidebar-bg); width: 280px !important; border-right: 1px solid var(--border-color); transition: transform 0.3s ease; }
        .offcanvas-header { border-bottom: 1px solid var(--border-color); padding: 1.5rem; }
        .offcanvas-title h5 { font-weight: 800; letter-spacing: -0.03em; color: #fff; font-size: 1.2rem; margin:0;}
        
        .offcanvas-body { padding: 1rem 0; display: flex; flex-direction: column; overflow-y: auto;}
        .nav-link { color: var(--text-secondary); padding: 12px 24px; font-size: 0.95rem; font-weight: 500; display: flex; align-items: center; border-left: 3px solid transparent; transition: all 0.2s; margin: 2px 12px; border-radius: 8px; border-left: none; cursor: pointer;}
        .nav-link:hover { color: #fff; background: rgba(255, 255, 255, 0.05); }
        .nav-link.active { color: #fff; background: var(--accent-gradient); box-shadow: 0 4px 12px rgba(59, 130, 246, 0.25); font-weight: 600;}
        .nav-link i { font-size: 1.2rem; margin-right: 14px; width: 20px; text-align: center; }

        .main-content { padding: 90px 24px 30px; transition: margin-left 0.3s ease; min-height: 100vh; }
        
        @media (min-width: 992px) {
            .offcanvas-start { transform: none !important; visibility: visible !important; position: fixed; height: 100vh; z-index: 1040;}
            .offcanvas-backdrop { display: none !important; }
            .app-header { left: 280px; }
            .main-content { margin-left: 280px; }
            .menu-toggle-btn { display: none; }
        }

        /* --- Cards & UI Elements --- */
        .card { background-color: var(--card-bg); border: 1px solid var(--border-color); border-radius: 16px; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2); transition: transform 0.2s, box-shadow 0.2s; margin-bottom: 24px; }
        .section-title { font-size: 1.5rem; font-weight: 700; margin-bottom: 24px; color: #fff; letter-spacing: -0.02em; }
        
        .dash-card { position: relative; overflow: hidden; border-radius: 16px; padding: 24px; border: none; }
        .dash-card-icon { position: absolute; right: -10px; bottom: -20px; font-size: 5rem; opacity: 0.15; transform: rotate(-15deg); }
        .dash-card h5 { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.9; margin-bottom: 10px; font-weight: 600;}
        .dash-card p { font-size: 2.2rem; font-weight: 800; margin: 0; line-height: 1;}
        .bg-gradient-blue { background: linear-gradient(135deg, #2563eb, #3b82f6); color: white; }
        .bg-gradient-purple { background: linear-gradient(135deg, #7c3aed, #8b5cf6); color: white; }
        .bg-gradient-orange { background: linear-gradient(135deg, #ea580c, #f59e0b); color: white; }
        .bg-gradient-green { background: linear-gradient(135deg, #059669, #10b981); color: white; }
        .bg-gradient-dark { background: linear-gradient(135deg, #1e293b, #334155); color: white; }

        /* --- Tables --- */
        .table-responsive { border-radius: 12px; overflow: auto; border: 1px solid var(--border-color); background: var(--card-bg);}
        .table { margin-bottom: 0; color: var(--text-primary); }
        .table th { background-color: rgba(0,0,0,0.2) !important; color: var(--text-secondary); font-weight: 600; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em; border-bottom: 1px solid var(--border-color); padding: 16px; white-space: nowrap;}
        .table td { background-color: transparent !important; border-bottom: 1px solid var(--border-color); padding: 16px; vertical-align: middle; white-space: nowrap;}
        .table-hover > tbody > tr:hover > td { background-color: rgba(255, 255, 255, 0.03) !important; }

        /* --- Buttons, Inputs & Forms --- */
        .btn { border-radius: 8px; font-weight: 500; transition: all 0.2s; }
        .btn:active { transform: translateY(1px); }
        .btn-primary { background: var(--primary-button-bg); border: none; box-shadow: 0 4px 10px rgba(59, 130, 246, 0.2); color: #fff;}
        .btn-primary:hover { background: var(--primary-button-hover); filter: brightness(1.1); }
        .form-control, .form-select { background-color: rgba(0,0,0,0.2); color: var(--text-primary); border: 1px solid var(--border-color); border-radius: 8px; padding: 10px 14px; transition: all 0.2s;}
        .form-control:focus, .form-select:focus { background-color: rgba(0,0,0,0.3); border-color: var(--accent-color); color: #fff; box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15); }
        .form-check-input:checked { background-color: var(--success-color); border-color: var(--success-color); }

        /* --- Modals & Login Container --- */
        .modal-content { background-color: var(--card-bg); border: 1px solid var(--border-color); border-radius: 16px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); }
        .modal-header { border-bottom: 1px solid var(--border-color); padding: 20px 24px; }
        .modal-footer { border-top: 1px solid var(--border-color); padding: 16px 24px; }
        .btn-close-white { filter: invert(1) grayscale(100%) brightness(200%); }

        .login-wrapper { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: radial-gradient(circle at top left, #1e293b, #0b0f19); }
        .login-container { width: 100%; max-width: 420px; padding: 20px; }
        .login-container .card { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 24px; box-shadow: 0 20px 40px rgba(0,0,0,0.4); padding: 2rem;}

        .nav-tabs { border-bottom: 1px solid var(--border-color); gap: 8px; padding: 0 16px; }
        .nav-tabs .nav-link { color: var(--text-secondary); border: none; border-bottom: 2px solid transparent; padding: 12px 16px; font-weight: 500; border-radius: 0;}
        .nav-tabs .nav-link.active { color: var(--accent-color); background: transparent; border-bottom: 2px solid var(--accent-color); }

        #adminLoader { position: fixed; inset: 0; background: rgba(11, 15, 25, 0.8); backdrop-filter: blur(5px); z-index: 9999; display: none; align-items: center; justify-content: center; }
    /* --- Status Toast --- */
    #adminToast {
        position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(20px);
        background: #1e293b; color: #fff; padding: 12px 22px; border-radius: 10px;
        font-size: 0.875rem; font-weight: 600; z-index: 99999;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4); border-left: 4px solid #22c55e;
        opacity: 0; transition: opacity 0.25s ease, transform 0.25s ease;
        pointer-events: none; white-space: nowrap;
    }
    #adminToast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    #adminToast.toast-danger { border-left-color: #ef4444; }
    #adminToast.toast-warning { border-left-color: #f59e0b; }
    </style>
</head>
<body>
<div id="adminToast"></div>

    <!-- Global Loader -->
    <div id="adminLoader">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
    </div>

    <!-- Login / Setup Area -->
    <div id="auth-container" class="login-wrapper">
        <!-- Master Setup -->
        <div id="admin-setup-section" style="display: none;" class="login-container">
            <div class="card">
                <div class="text-center mb-4">
                    <div style="width: 60px; height: 60px; background: var(--accent-gradient); border-radius: 16px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 16px;"><i class="bi bi-shield-lock-fill fs-2 text-white"></i></div>
                    <h3 class="fw-bold text-white">Admin Setup</h3><p class="text-secondary small">Create the master administrator account</p>
                </div>
                <form id="adminSetupForm">
                    <div class="mb-3"> <label class="form-label">Master Email</label> <input type="email" class="form-control" id="setupEmail" placeholder="admin@nexus.com" required> </div>
                    <div class="mb-4"> <label class="form-label">Master Password</label> <input type="password" class="form-control" id="setupPassword" placeholder="Minimum 6 characters" required minlength="6"> </div>
                    <div id="adminSetupStatus"></div>
                    <button type="submit" class="btn btn-primary w-100 py-2 fs-6">Initialize System</button>
                </form>
            </div>
        </div>

        <!-- Login Section -->
        <div id="admin-login-section" style="display: none;" class="login-container">
            <div class="card">
                <div class="text-center mb-4">
                    <div style="width: 60px; height: 60px; background: var(--accent-gradient); border-radius: 16px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 16px;"><i class="bi bi-fingerprint fs-2 text-white"></i></div>
                    <h3 class="fw-bold text-white">Nexus Admin</h3><p class="text-secondary small">Secure Dashboard Access</p>
                </div>
                <form id="adminLoginForm">
                    <div class="mb-3"> <label class="form-label">Email Address</label> <input type="email" class="form-control form-control-lg" id="adminEmail" placeholder="admin@domain.com" required> </div>
                    <div class="mb-4"> <label class="form-label">Password</label> <input type="password" class="form-control form-control-lg" id="adminPassword" placeholder="••••••••" required> </div>
                    <div id="adminLoginStatus"></div>
                    <button type="submit" class="btn btn-primary w-100 py-2 fs-5">Authenticate</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Main Admin Panel Area -->
    <div id="admin-main-area" style="display: none;">
        
        <!-- App Header -->
        <header class="app-header">
            <div class="d-flex align-items-center">
                <button class="menu-toggle-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminSidebar"><i class="bi bi-list"></i></button>
                <h1 class="header-title" id="adminPageTitle">Dashboard Overview</h1>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="d-none d-sm-block text-secondary small fw-medium" id="adminUserEmailShort"></span>
                <button class="btn btn-sm btn-outline-danger" id="adminLogoutBtnHeader"><i class="bi bi-power"></i> Exit</button>
            </div>
        </header>

        <!-- Sidebar Navigation -->
        <div class="offcanvas offcanvas-start" tabindex="-1" id="adminSidebar">
            <div class="offcanvas-header">
                <div class="d-flex align-items-center gap-2">
                    <div style="width:32px; height:32px; background: var(--accent-gradient); border-radius: 8px; display:flex; align-items:center; justify-content:center;"><i class="bi bi-controller text-white"></i></div>
                    <h5 class="offcanvas-title">NEXUS</h5>
                </div>
                <button type="button" class="btn-close btn-close-white d-lg-none" data-bs-dismiss="offcanvas"></button>
            </div>
            <div class="offcanvas-body">
                <ul class="nav flex-column gap-1" id="sidebarNavLinks">
                    <li class="nav-item"> <a class="nav-link active" data-section="dashboard-section"><i class="bi bi-grid-1x2-fill"></i> Overview</a> </li>
                    
                    <div class="text-uppercase text-secondary small fw-bold px-4 pt-3 pb-2 mt-2" style="letter-spacing: 0.1em;">Gaming Setup</div>
                    <li class="nav-item"> <a class="nav-link" data-section="games-section"><i class="bi bi-joystick"></i> Game Titles</a> </li>
                    <li class="nav-item"> <a class="nav-link" data-section="promotions-section"><i class="bi bi-megaphone-fill"></i> Promotions</a> </li>
                    <li class="nav-item"> <a class="nav-link" data-section="tournaments-section"><i class="bi bi-trophy-fill"></i> Tournaments</a> </li>
                    <li class="nav-item"> <a class="nav-link" data-section="tournament-management-section"><i class="bi bi-flag-fill"></i> Match Results</a> </li>
                    <li class="nav-item"> <a class="nav-link" data-section="leaderboard-mgt-section"><i class="bi bi-bar-chart-line-fill"></i> Leaderboards</a> </li>
                    
                    <div class="text-uppercase text-secondary small fw-bold px-4 pt-3 pb-2 mt-2" style="letter-spacing: 0.1em;">Users & Finance</div>
                    <li class="nav-item"> <a class="nav-link" data-section="users-section"><i class="bi bi-people-fill"></i> Players Base</a> </li>
                    <li class="nav-item"> <a class="nav-link" data-section="user-analytics-section"><i class="bi bi-pie-chart-fill"></i> Analytics</a> </li>
                    <li class="nav-item"> <a class="nav-link" data-section="transaction-history-section"><i class="bi bi-clock-history"></i> Txn History</a> </li>
                    <li class="nav-item"> <a class="nav-link" data-section="withdrawals-section"><i class="bi bi-bank2"></i> Withdrawals <span class="badge bg-danger rounded-pill ms-auto" id="pendingWithdrawalCountBadge" style="display: none;">0</span></a> </li>
                    <li class="nav-item"> <a class="nav-link" data-section="deposit-section"><i class="bi bi-wallet-fill"></i> Deposits <span class="badge bg-warning text-dark rounded-pill ms-auto" id="pendingDepositCountBadge" style="display: none;">0</span></a> </li>
                    <li class="nav-item"> <a class="nav-link" data-section="referrals-section"><i class="bi bi-diagram-3-fill"></i> Referrals <span class="badge bg-info text-dark rounded-pill ms-auto" id="pendingReferralCountBadge" style="display: none;">0</span></a> </li>
                    
                    <div class="text-uppercase text-secondary small fw-bold px-4 pt-3 pb-2 mt-2" style="letter-spacing: 0.1em;">System</div>
                    <li class="nav-item"> <a class="nav-link text-warning fw-bold" style="background: rgba(245, 158, 11, 0.1);" data-section="demo-link-section"><i class="bi bi-link-45deg"></i> App / Promo Link</a> </li>
                    <li class="nav-item"> <a class="nav-link text-success fw-bold" style="background: rgba(16, 185, 129, 0.1);" data-section="support-manager-section"><i class="bi bi-headset"></i> Support Links</a> </li>
                    <li class="nav-item"> <a class="nav-link" data-section="notifications-section"><i class="bi bi-bell-fill"></i> Push Alerts</a> </li>
                    <li class="nav-item"> <a class="nav-link text-info" data-section="staff-management-section"><i class="bi bi-person-badge-fill"></i> Staff / Roles</a> </li>
                    <li class="nav-item"> <a class="nav-link" data-section="theme-section"><i class="bi bi-palette-fill"></i> Appearance</a> </li>
                    <li class="nav-item"> <a class="nav-link" data-section="settings-section"><i class="bi bi-gear-fill"></i> App Settings</a> </li>
                </ul>

                <div class="mt-auto px-4 pt-4 pb-3">
                    <button id="quickThemeToggle" class="btn w-100 d-flex align-items-center justify-content-center gap-2 shadow-sm" style="background: rgba(0,0,0,0.2); color: var(--text-primary); border: 1px solid var(--border-color); border-radius: 10px; padding: 10px;">
                        <i class="bi bi-brightness-high-fill fs-5" id="quickThemeIcon"></i>
                        <span id="quickThemeText" class="fw-bold small">Light Mode</span>
                    </button>
                </div>
            </div>
        </div>

        <main class="main-content" id="adminMainContent">
            
            <!-- Dashboard Section -->
            <section id="dashboard-section" class="section active">
                <div class="row g-4 mb-4">
                    <div class="col-12 col-md-6 col-xl-3"><div class="card dash-card bg-gradient-blue shadow-lg h-100"><h5>Total Players</h5><p id="statTotalUsers">--</p><i class="bi bi-people-fill dash-card-icon"></i></div></div>
                    <div class="col-12 col-md-6 col-xl-3"><div class="card dash-card bg-gradient-purple shadow-lg h-100"><h5>Active Matches</h5><p id="statActiveTournaments">--</p><i class="bi bi-controller dash-card-icon"></i></div></div>
                    <div class="col-12 col-md-6 col-xl-3"><div class="card dash-card bg-gradient-orange shadow-lg h-100"><h5>Pending Payouts</h5><p id="statPendingWithdrawals">--</p><i class="bi bi-cash-stack dash-card-icon"></i></div></div>
                    <div class="col-12 col-md-6 col-xl-3"><div class="card dash-card bg-gradient-green shadow-lg h-100"><h5>Completed Payouts</h5><p id="statCompletedWithdrawals">--</p><i class="bi bi-check-circle-fill dash-card-icon"></i></div></div>
                </div>
                <div class="row g-4 mb-4">
                    <div class="col-12 col-md-4"><div class="card dash-card bg-gradient-dark h-100 py-3"><h5 class="text-muted mb-2">Total Games</h5><p id="statTotalGames" class="fs-3">--</p><i class="bi bi-joystick dash-card-icon"></i></div></div>
                    <div class="col-12 col-md-4"><div class="card dash-card bg-gradient-dark h-100 py-3"><h5 class="text-muted mb-2">Promotions</h5><p id="statTotalPromotions" class="fs-3">--</p><i class="bi bi-megaphone-fill dash-card-icon"></i></div></div>
                    <div class="col-12 col-md-4"><div class="card dash-card bg-gradient-dark h-100 py-3"><h5 class="text-muted mb-2">Finished Matches</h5><p id="statFinishedTournaments" class="fs-3">--</p><i class="bi bi-flag-fill dash-card-icon"></i></div></div>
                </div>
                <div class="card p-4">
                    <h5 class="mb-4 fw-bold">Player Acquisition (Last 7 Days)</h5>
                    <div style="height: 300px;"><canvas id="newUserChart"></canvas></div>
                </div>
            </section>

            <!-- Games Section -->
            <section id="games-section" class="section">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="section-title m-0">Gaming Titles</h2>
                    <button class="btn btn-primary" id="addNewGameBtn"><i class="bi bi-plus-lg"></i> Add Game</button>
                </div>
                <div class="table-responsive"><table class="table table-hover"><thead><tr><th>Cover</th><th>Game Name</th><th>Internal ID</th><th>Manage</th></tr></thead><tbody id="gamesTableBody"></tbody></table></div>
            </section>

            <!-- Promotions Section -->
            <section id="promotions-section" class="section">
                <div class="d-flex justify-content-between align-items-center mb-4">
                     <h2 class="section-title m-0">Promo Banners</h2>
                     <button class="btn btn-primary" id="addNewPromotionBtn"><i class="bi bi-plus-lg"></i> Add Promo</button>
                </div>
                <div class="table-responsive"><table class="table table-hover"><thead><tr><th>Banner</th><th>Redirect Link</th><th>Manage</th></tr></thead><tbody id="promotionsTableBody"></tbody></table></div>
             </section>

            <!-- Tournaments Section -->
            <section id="tournaments-section" class="section">
                 <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                     <h2 class="section-title m-0">Active Tournaments</h2>
                     <button class="btn btn-primary" id="addNewTournamentBtn"><i class="bi bi-plus-lg"></i> Create Match</button>
                 </div>
                 <div class="table-responsive"><table class="table table-hover"><thead><tr><th>Title</th><th>Game</th><th>Entry</th><th>Pool</th><th>Date</th><th>Status</th><th>Filled</th><th>Actions</th></tr></thead><tbody id="tournamentsTableBody"></tbody></table></div>
            </section>
            
            <!-- Tournament Management (Results) Section -->
            <section id="tournament-management-section" class="section">
                <h2 class="section-title">Declare Winners & Payouts</h2>
                <div class="card p-4">
                    <div class="row mb-4"><div class="col-md-6"><label class="form-label">Select Finished Match</label><select class="form-select form-select-lg" id="tmsTournamentSelect"></select></div></div>
                    <div id="tmsStatus" class="mb-3"></div>
                    <div id="tmsPlayerListContainer" style="display: none;">
                        <div class="table-responsive border border-secondary mb-4">
                            <table class="table table-hover mb-0"><thead><tr><th>Player</th><th>Game UID</th><th>Kill Prize</th><th>Kills</th><th>Bonus (₹)</th><th>Rank</th><th>Total Payout</th></tr></thead><tbody id="tmsPlayerListTableBody"></tbody></table>
                        </div>
                        <div class="text-end"><button class="btn btn-success btn-lg px-5" id="creditWinningsBtn"><i class="bi bi-check2-all"></i> Process All Payouts</button></div>
                    </div>
                </div>
            </section>

            <!-- Users Section -->
            <section id="users-section" class="section">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                    <h2 class="section-title m-0">Player Database</h2>
                    <div class="d-flex gap-2">
                        <input type="search" class="form-control" id="userSearchInput" placeholder="Search Email/Name...">
                        <button class="btn btn-outline-info" id="downloadUsersPdfBtn"><i class="bi bi-file-pdf"></i> Export</button>
                        <button class="btn btn-primary" id="addNewUserBtn"><i class="bi bi-person-plus"></i> Add User</button>
